<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.junyoung.minigamesapp">

    <!-- ───────────── 권한 ───────────── -->
    <!-- 인터넷 (웹뷰 + 광고 필수) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 네트워크 상태 확인 (광고 SDK) -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 외부 앱 연동 쿼리 (카카오, Google 등) -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
        <!-- 브라우저 / OAuth 팝업 처리 -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
        <!-- 카카오 앱 -->
        <package android:name="com.kakao.talk" />
    </queries>

    <application
        android:label="도전! 미니 게임"
        android:icon="@mipmap/ic_launcher"
        android:hardwareAccelerated="true"
        android:usesCleartextTraffic="false">
        <!-- usesCleartextTraffic=false: HTTPS만 허용 (보안) -->
        <!-- 게임 사이트가 HTTPS라면 false 유지. HTTP 리소스 있으면 true로 변경 -->

        <!-- AdMob 앱 ID -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-8518556382646891~2852387790" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- 스플래시 → 일반 테마 전환 -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <!-- 런처 등록 -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Flutter 임베딩 v2 -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

    </application>
</manifest>
